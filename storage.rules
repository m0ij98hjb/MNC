rules_version = '2';
// ⚠️ IMPORTANT — READ BEFORE DEPLOYING:
// This repo did not previously track a storage.rules file, which means whatever
// Storage rules are live today (governing e.g. settings/director-photo uploads,
// camera assets, content-management uploads) only exist in the Firebase Console
// and are NOT reflected here. `firebase deploy --only storage` REPLACES the
// entire ruleset — it does not merge. Before deploying this file, open
// Firebase Console → Storage → Rules, copy the current live rules, and merge
// them into this file (add their `match` blocks alongside the ones below) so
// existing upload features keep working. Do not deploy this file as-is without
// doing that merge first.
service firebase.storage {
  match /b/{bucket}/o {

    // Purchasing / Procurement module attachments — request attachments,
    // quotations, purchase orders, warehouse receipt photos, supplier files,
    // and e-signatures. Fine-grained per-role checks live in Firestore Rules
    // (which gate the associated documents); any authenticated app user may
    // read/write these paths.
    match /purchaseRequests/{requestId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /purchaseOrders/{orderId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /purchasingSuppliers/{supplierId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /warehouseReceipts/{receiptId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /purchaseSignatures/{requestId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // No catch-all here on purpose — see the warning above. Merge in the
    // existing live rules (director photo, cameras, content uploads, etc.)
    // before this file is ever deployed.
  }
}
