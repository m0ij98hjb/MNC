rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Suppliers collection:
    // - Anyone (unauthenticated) can CREATE a new supplier registration
    // - Only authenticated admins can READ, UPDATE, DELETE
    match /suppliers/{supplierId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ══════════════════════════════════════════════════════════════
    // Purchasing / Procurement module — fully independent of the rules
    // above. Its own role system (purchasingUsers) drives every check,
    // and the workflow's state machine is enforced here (not just in
    // the UI) so no role can skip a stage of the approval chain.
    // ══════════════════════════════════════════════════════════════

    function purchIsSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'mm5329844@gmail.com';
    }

    function purchRole() {
      return (request.auth != null && request.auth.token.email == 'engineer.tester@mnc.com')
        ? 'procurement_manager'
        : (request.auth != null && exists(/databases/$(database)/documents/purchasingUsers/$(request.auth.uid))
            ? get(/databases/$(database)/documents/purchasingUsers/$(request.auth.uid)).data.role
            : null);
    }

    function purchInRoles(rolesList) {
      return purchIsSuperAdmin() || (request.auth != null && purchRole() in rolesList);
    }

    // Role/account profiles
    match /purchasingUsers/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || purchIsSuperAdmin());
      allow create, update, delete: if purchIsSuperAdmin();
    }

    // Auto-increment counters (requestNumber / poNumber) — used inside client transactions
    match /purchasingMeta/{docId} {
      allow read, write: if request.auth != null;
    }

    // Central admin users registry — manages main-dashboard access permissions
    // Only super admin can create/update/delete; authenticated users can read their own doc
    match /adminUsers/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || purchIsSuperAdmin());
      allow create, update, delete: if purchIsSuperAdmin();
    }

    match /purchaseRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.requesterUid == request.auth.uid
        && request.resource.data.status == 'pending_project_manager_approval'
        && (purchRole() != null || purchIsSuperAdmin());

      allow read: if request.auth != null && (
        resource.data.requesterUid == request.auth.uid ||
        purchInRoles(['project_manager','engineering_manager','procurement_manager','procurement_officer',
                       'general_manager','accountant','store_keeper','viewer'])
      );

      allow update: if request.auth != null && (
        // Requester edits + resubmits after being returned for revision
        (resource.data.requesterUid == request.auth.uid
          && resource.data.status == 'returned_for_revision'
          && request.resource.data.status == 'pending_project_manager_approval') ||

        // Stage 1 — Project Manager
        (purchRole() == 'project_manager'
          && resource.data.status == 'pending_project_manager_approval'
          && request.resource.data.status in ['pending_engineering_manager_approval','rejected','returned_for_revision']) ||

        // Stage 2 — Engineering Manager
        (purchRole() == 'engineering_manager'
          && resource.data.status == 'pending_engineering_manager_approval'
          && request.resource.data.status in ['pending_procurement_approval','rejected','returned_for_revision']) ||

        // Stage 3 — Procurement Manager (routes to GM stage or straight to Approved)
        (purchRole() == 'procurement_manager'
          && resource.data.status == 'pending_procurement_approval'
          && request.resource.data.status in ['pending_gm_approval','approved','rejected','returned_for_revision']) ||

        // Stage 4 — General Manager (conditional, high-value requests only)
        (purchRole() == 'general_manager'
          && resource.data.status == 'pending_gm_approval'
          && request.resource.data.status in ['approved','rejected','returned_for_revision']) ||

        // Procurement execution pipeline
        (purchRole() in ['procurement_officer','procurement_manager']
          && resource.data.status in ['approved','rfq_requested','quotations_received','po_issued']
          && request.resource.data.status in ['rfq_requested','quotations_received','po_issued','delivered_pending_receipt']) ||

        // Store keeper receiving
        (purchRole() == 'store_keeper'
          && resource.data.status == 'delivered_pending_receipt'
          && request.resource.data.status == 'received') ||

        // Completion / archive
        (purchRole() in ['procurement_manager','store_keeper']
          && resource.data.status == 'received'
          && request.resource.data.status == 'completed') ||
        (purchRole() == 'procurement_manager'
          && resource.data.status == 'completed'
          && request.resource.data.status == 'archived') ||

        purchIsSuperAdmin()
      );

      allow delete: if purchIsSuperAdmin();

      // Per-stage approval records (decision, signature, approver) — append-only
      match /approvals/{stageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }

      // Full activity log — append-only, never editable or deletable
      match /history/{entryId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // Procurement's own vendor directory — intentionally separate from `suppliers`
    // above (different schema/purpose) to avoid any interference with that module.
    match /purchasingSuppliers/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['procurement_officer','procurement_manager']);
      allow delete: if purchIsSuperAdmin();
    }

    match /purchaseRFQs/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['procurement_officer','procurement_manager']);
      allow delete: if purchIsSuperAdmin();

      match /quotations/{supplierId} {
        allow read: if request.auth != null;
        allow create, update: if purchInRoles(['procurement_officer','procurement_manager']);
        allow delete: if purchIsSuperAdmin();
      }
    }

    match /purchaseOrders/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['procurement_officer','procurement_manager']);
      allow delete: if purchIsSuperAdmin();
    }

    match /warehouseReceipts/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['store_keeper','procurement_manager']);
      allow delete: if purchIsSuperAdmin();
    }

    match /purchaseNotifications/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if purchIsSuperAdmin();
    }

    // Per-project approved budget registry (Phase 2 — Budget Control)
    match /projectBudgets/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['procurement_manager']);
      allow delete: if purchIsSuperAdmin();
    }

    // Running warehouse stock levels (Phase 2 — Warehouse Availability)
    match /warehouseStock/{id} {
      allow read: if request.auth != null;
      allow create, update: if purchInRoles(['store_keeper','procurement_officer','procurement_manager']);
      allow delete: if purchIsSuperAdmin();
    }

    // Log of stock issued directly from warehouse instead of purchased — append-only
    match /warehouseIssues/{id} {
      allow read: if request.auth != null;
      allow create: if purchInRoles(['procurement_officer','procurement_manager']);
      allow update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
